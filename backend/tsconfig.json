{
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "./src",

    "target": "ES2023",

    "module": "ESNext",
    "moduleResolution": "bundler",

    "strict": true,
    "esModuleInterop": true,

    "types": ["node"],

    "skipLibCheck": true
  },

  "include": ["src/**/*"],

  "exclude": ["node_modules", "prisma", "prisma.config.ts", "./src/generated"]
}
